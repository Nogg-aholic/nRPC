{
  "name": "@nogg-aholic/nrpc",
  "description": "Small binary RPC codec for compact value encoding and generic RPC message framing.",
  "version": "0.4.6",
  "homepage": "https://github.com/Nogg-aholic/nRPC#readme",
  "license": "MIT",
  "type": "module",
  "bin": {
    "nrpc-generate-declaration-lines": "dist/generate-declaration-lines-cli.js",
    "nrpc-generate-codec": "dist/generate-codec-cli.js",
    "nrpc-generate-endpoint-surface": "dist/generate-endpoint-surface-cli.js",
    "nrpc-generate-endpoint-global-dts": "dist/generate-endpoint-global-dts-cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./declaration-lines-generator": {
      "types": "./dist/declaration-lines-generator.d.ts",
      "import": "./dist/declaration-lines-generator.js"
    },
    "./codec-generator": {
      "types": "./dist/codec-generator.d.ts",
      "import": "./dist/codec-generator.js"
    },
    "./contract-runtime-inline-generator": {
      "types": "./dist/contract-runtime-inline-generator.d.ts",
      "import": "./dist/contract-runtime-inline-generator.js"
    },
    "./endpoint-surface-generator": {
      "types": "./dist/endpoint-surface-generator.d.ts",
      "import": "./dist/endpoint-surface-generator.js"
    },
    "./http-route-generator": {
      "types": "./dist/http-route-generator.d.ts",
      "import": "./dist/http-route-generator.js"
    },
    "./docs": {
      "types": "./dist/docs.d.ts",
      "import": "./dist/docs.js"
    },
    "./docs-runtime": {
      "types": "./dist/docs-runtime.d.ts",
      "import": "./dist/docs-runtime.js"
    },
    "./openapi-types": {
      "types": "./dist/openapi-types.d.ts",
      "import": "./dist/openapi-types.js"
    },
    "./scalar-html": {
      "types": "./dist/scalar-html.d.ts",
      "import": "./dist/scalar-html.js"
    },
    "./openapi-generator": {
      "types": "./dist/openapi-generator.d.ts",
      "import": "./dist/openapi-generator.js"
    },
    "./http-route-runtime": {
      "types": "./dist/http-route-runtime.d.ts",
      "import": "./dist/http-route-runtime.js"
    },
    "./web-runtime": {
      "types": "./dist/web-runtime.d.ts",
      "import": "./dist/web-runtime.js"
    },
    "./generated-codec-runtime": {
      "types": "./dist/generated-codec-runtime.d.ts",
      "import": "./dist/generated-codec-runtime.js"
    },
    "./generate-declaration-lines-cli": {
      "types": "./dist/generate-declaration-lines-cli.d.ts",
      "import": "./dist/generate-declaration-lines-cli.js"
    },
    "./generate-codec-cli": {
      "types": "./dist/generate-codec-cli.d.ts",
      "import": "./dist/generate-codec-cli.js"
    },
    "./generate-endpoint-surface-cli": {
      "types": "./dist/generate-endpoint-surface-cli.d.ts",
      "import": "./dist/generate-endpoint-surface-cli.js"
    },
    "./generate-endpoint-global-dts-cli": {
      "types": "./dist/generate-endpoint-global-dts-cli.d.ts",
      "import": "./dist/generate-endpoint-global-dts-cli.js"
    },
    "./synthetic-rpc-surface": {
      "types": "./dist/synthetic-rpc-surface.d.ts",
      "import": "./dist/synthetic-rpc-surface.js"
    },
    "./structural-contract-generator": {
      "types": "./dist/structural-contract-generator.d.ts",
      "import": "./dist/structural-contract-generator.js"
    }
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nogg-aholic/nRPC"
  },
  "bugs": {
    "url": "https://github.com/Nogg-aholic/nRPC/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "keywords": [
    "rpc",
    "binary",
    "codec",
    "transport",
    "serialization",
    "typescript"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunx tsc -p ./tsconfig.json",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
